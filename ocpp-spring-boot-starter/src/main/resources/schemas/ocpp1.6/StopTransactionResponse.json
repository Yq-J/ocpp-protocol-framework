{
  "$schema": "http://json-schema.org/draft-04/schema#",
  "$ref": "#/definitions/StopTransactionResponsePayload",
  "definitions": {
    "StopTransactionResponsePayload": {
      "type": "object",
      "properties": {
        "idTagInfo": {
          "type": "object",
          "properties": {
            "expiryDate": {
              "type": "string",
              "format": "date-time"
            },
            "parentIdTag": {
              "type": "string",
              "maxLength": 20
            },
            "status": {
              "type": "string",
              "additionalProperties": false,
              "enum": [
                "Accepted",
                "Blocked",
                "Expired",
                "Invalid",
                "ConcurrentTx"
              ]
            }
          },
          "additionalProperties": false,
          "required": [
            "status"
          ]
        }
      }
    }
  }
}
